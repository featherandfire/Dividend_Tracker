# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# Personal portfolio data — exports/imports with real positions, anywhere in the repo.
# Covers CSVs, Excel files, and any folder you might park personal data in.
*.csv
*.xlsx
*.xls
*.tsv
/portfolio/
/holdings/
/private/

# vercel
.vercel

# Supabase CLI workspace (regenerated on every link/gen)
supabase/.temp/
supabase/.branches/

# typescript
*.tsbuildinfo
next-env.d.ts
