# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase — Project Settings → API → Project URL + Project API keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only — bypasses RLS. Used by the Finnhub proxy route to write into ticker_cache.
# In Supabase's new key model: Project Settings → API → "secret_key" (sb_secret_...) OR the legacy "service_role" JWT.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Finnhub — finnhub.io/dashboard (free tier: 60 req/min)
FINNHUB_API_KEY=your-finnhub-key

# Financial Modeling Prep — site.financialmodelingprep.com/developer/docs/dashboard (free tier: 250 req/day)
# Used as a tiebreaker dividend source alongside Finnhub + Yahoo.
FMP_API_KEY=your-fmp-key

# Polygon.io — polygon.io/dashboard (free tier: 5 req/min, unlimited daily)
# Used for authoritative on-demand validation of dividend payouts.
POLYGON_API_KEY=your-polygon-key

# Personal access token for the Supabase CLI (type generation only — not used by the app at runtime).
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxx

